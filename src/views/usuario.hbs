<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mi Perfil</title>
  <link rel="stylesheet" href="/css/usuario.css">
</head>
<body>

  <header class="user-header">
    <h1 class="user-title">Mi Perfil de Usuario</h1>
    <p class="user-welcome">Bienvenido {{user.username}} (USUARIO)</p>
    <a href="/logout" class="logout-btn">Cerrar sesión</a>
  </header>

  <div class="user-container">
    <h2 class="user-subtitle">Mis Datos</h2>
    
    <div class="user-info">
      <table class="user-table">
        <tr>
          <th>ID</th>
          <td>{{user.id_usuario}}</td>
        </tr>
        <tr>
          <th>Email</th>
          <td>{{user.email}}</td>
        </tr>
        <tr>
          <th>Nombre de usuario</th>
          <td>{{user.username}}</td>
        </tr>
        <tr>
          <th>Tipo de cuenta</th>
          <td>
            <span class="badge bg-primary">USUARIO</span>
          </td>
        </tr>
      </table>
    </div>

    <div class="user-actions">
      <h3>Acciones disponibles</h3>
      <ul>
        <li><a href="/cambiar-password" class="action-link">Cambiar mi contraseña</a></li>
        <li><a href="/editar-perfil" class="action-link">Editar mi perfil</a></li>
        <li><a href="/mis-actividades" class="action-link">Ver mis actividades</a></li>
      </ul>
    </div>
  </div>



</body>
</html>