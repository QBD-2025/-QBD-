<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel de Administración</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>

  <header class="admin-header bg-dark text-white p-3">
    <h1 class="admin-title">Panel de Administración</h1>
    <p class="admin-welcome">Bienvenido {{user.username}} (ADMIN)</p>
  </header>

  <div class="admin-container container mt-4">
    <h2 class="admin-subtitle mb-4">Usuarios del Sistema</h2>
    <form method="POST" action="/admin/cambiar-rol" class="admin-form">
      <table class="admin-table table table-striped table-hover">
        <thead class="table-dark">
          <tr>
            <th>ID</th>
            <th>Email</th>
            <th>Nombre</th>
            <th>Rol actual</th>
            <th>Cambiar a</th>
          </tr>
        </thead>
        <tbody>
          {{#each usuarios}}    
          <tr>
            <td>{{this.id_usuario}}</td>
            <td>{{this.email}}</td>
            <td>{{this.username}}</td>
            <td>
              {{#if (eq this.id_tp_usuario 3)}}
                <span class="badge bg-danger">ADMIN</span>
              {{else if (eq this.id_tp_usuario 2)}}
                <span class="badge bg-warning text-dark">EDITOR</span>
              {{else}}
                <span class="badge bg-primary">USUARIO</span>
              {{/if}}
            </td>
            <td>
              <select name="roles[{{this.id_usuario}}]" class="form-select role-select">
                <option value="1" {{#if (eq this.id_tp_usuario 1)}}selected{{/if}}>USUARIO</option>
                <option value="2" {{#if (eq this.id_tp_usuario 2)}}selected{{/if}}>EDITOR</option>
                <option value="3" {{#if (eq this.id_tp_usuario 3)}}selected{{/if}}>ADMIN</option>
              </select>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>

      <button type="submit" class="admin-btn btn btn-primary mt-3">Actualizar permisos</button>
    </form>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
  document.querySelector("form").addEventListener("submit", () => {
    console.log("Formulario enviado");
    setTimeout(() => {
      alert("¡Formulario fue enviado! Verifica en el backend los datos.");
    }, 100);
  });
</script>
</body>
</html>