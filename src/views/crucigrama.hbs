<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Crucigrama Dinámico</title>
  <link rel="stylesheet" href="/css/crucigrama.css" />
</head>
<body>

  <main class="container" role="main" aria-label="Crucigrama">
    <h1 class="title">Crucigrama Dinámico</h1>

    <div id="crucigrama-container">
      <!-- Aquí se carga dinámicamente el crucigrama -->
    </div>

    <section class="controls">
      <button id="checkBtn" type="button" class="btn primary">Verificar</button>
      <button id="resetBtn" type="button" class="btn secondary">Reiniciar</button>
      <button id="nextBtn" type="button" class="btn tertiary">Siguiente Crucigrama</button>
      <p id="resultMsg" aria-live="polite" class="result-message"></p>
    </section>

    <section class="clues" id="clues-container">
      <!-- Aquí se cargan las pistas -->
    </section>
  </main>

  <script>
    // Los crucigramas llegan del servidor como JSON incrustado
    const crucigramas = {{{json crucigramas}}};

    let current = 0;

    const crucigramaContainer = document.getElementById('crucigrama-container');
    const cluesContainer = document.getElementById('clues-container');
    const checkBtn = document.getElementById('checkBtn');
    const resetBtn = document.getElementById('resetBtn');
    const nextBtn = document.getElementById('nextBtn');
    const resultMsg = document.getElementById('resultMsg');

    function renderGrid(grid) {
  const gridDiv = document.createElement('div');
  gridDiv.className = 'crucigrama-grid';

  let maxRows = grid.length;
  let maxCols = Math.max(...grid.map(row => row.length));

  gridDiv.style.display = 'grid';
  gridDiv.style.gridTemplateColumns = `repeat(${maxCols}, 50px)`;
  gridDiv.style.gridAutoRows = '50px';
  gridDiv.style.gap = '6px';
  gridDiv.style.justifyContent = 'center';

  for (let r = 0; r < maxRows; r++) {
    for (let c = 0; c < maxCols; c++) {
      const cell = grid[r][c];
      const cellDiv = document.createElement('div');
      cellDiv.style.gridRowStart = r + 1;
      cellDiv.style.gridColumnStart = c + 1;

      if (cell) {
        const input = document.createElement('input');
        input.type = 'text';
        input.className = 'cell';
        input.maxLength = 1;
        input.autocomplete = 'off';
        input.spellcheck = false;

        if (cell.number) input.setAttribute('data-number', cell.number);

        cellDiv.appendChild(input);
      } else {
        // Celdas vacías o inactivas
        cellDiv.className = 'empty-cell';
      }

      gridDiv.appendChild(cellDiv);
    }
  }

  return gridDiv;
}


    function renderClues(clues) {
      const fragment = document.createDocumentFragment();

      const h2Across = document.createElement('h2');
      h2Across.textContent = "Horizontales";
      fragment.appendChild(h2Across);

      const ulAcross = document.createElement('ul');
      clues.filter(c => c.direction === 'across').forEach(c => {
        const li = document.createElement('li');
        li.innerHTML = `<strong>${c.number}:</strong> ${c.clue}`;
        ulAcross.appendChild(li);
      });
      fragment.appendChild(ulAcross);

      const h2Down = document.createElement('h2');
      h2Down.textContent = "Verticales";
      fragment.appendChild(h2Down);

      const ulDown = document.createElement('ul');
      clues.filter(c => c.direction === 'down').forEach(c => {
        const li = document.createElement('li');
        li.innerHTML = `<strong>${c.number}:</strong> ${c.clue}`;
        ulDown.appendChild(li);
      });
      fragment.appendChild(ulDown);

      return fragment;
    }

    // Renderiza el crucigrama y pistas actuales
    function renderCurrent() {
      resultMsg.textContent = "";
      crucigramaContainer.innerHTML = '';
      cluesContainer.innerHTML = '';

      const { grid, clues } = crucigramas[current];

      const gridEl = renderGrid(grid);
      crucigramaContainer.appendChild(gridEl);

      cluesContainer.appendChild(renderClues(clues));
    }

    // Función para obtener las posiciones de las respuestas para validar
    // Calcula basado en grid las posiciones de las respuestas según las pistas:
    // Para este ejemplo, definimos manualmente posiciones en la data (para simplicidad).
    const answersList = crucigramas.map(c => {
      // Obtenemos respuestas y posiciones manualmente para validar
      // (En prod lo ideal es incluir posiciones en el json)
      if(c.id === 1) {
        return {
          1: "SOLAR",
          2: "CAS",
          positions: {
            1: [ {row:2, col:1}, {row:2, col:2}, {row:2, col:3}, {row:2, col:4}, {row:2, col:5} ],
            2: [ {row:0, col:0}, {row:1, col:0}, {row:2, col:0} ]
          }
        };
      } else if(c.id === 2) {
        return {
          1: "PIZZA",
          3: "SOL",
          positions: {
            1: [ {row:0, col:0}, {row:0, col:1}, {row:0, col:2}, {row:0, col:3}, {row:0, col:4} ],
            3: [ {row:0, col:3}, {row:1, col:3}, {row:2, col:3} ]
          }
        };
      } else if(c.id === 3) {
        return {
          1: "ESCUELA",
          2: "OIR",
          positions: {
            1: [ {row:0, col:0}, {row:0, col:1}, {row:0, col:2}, {row:0, col:3}, {row:0, col:4}, {row:0, col:5}, {row:0, col:6} ],
            2: [ {row:1, col:6}, {row:2, col:6}, {row:3, col:6} ]
          }
        };
      } else if(c.id === 4) {
        return {
          1: "MUS",
          2: "LA",
          positions: {
            1: [ {row:0, col:0}, {row:1, col:0}, {row:2, col:0} ],
            2: [ {row:1, col:4}, {row:2, col:4} ]
          }
        };
      }
      return {};
    });

    function checkAnswers() {
      const answers = answersList[current];
      const gridEl = crucigramaContainer.querySelector('.crucigrama-grid');
      const inputs = gridEl.querySelectorAll('.cell:not(.empty)');
      const numCols = gridEl.style.gridTemplateColumns.split(' ').length || 6;
      const numRows = gridEl.style.gridAutoRows ? parseInt(gridEl.style.gridAutoRows) : 4;

      // Mapa inputs en matriz
      const cellMatrix = [];
      for(let r = 0; r < numRows; r++) {
        cellMatrix[r] = [];
        for(let c = 0; c < numCols; c++) {
          const idx = r * numCols + c;
          cellMatrix[r][c] = inputs[idx] || null;
        }
      }

      let allCorrect = true;

      inputs.forEach(input => {
        input.classList.remove('correct', 'incorrect', 'shake');
      });

      for (const [num, answer] of Object.entries(answers)) {
        if(num === 'positions') continue;
        const posList = answers.positions[num];
        for (let i = 0; i < answer.length; i++) {
          const { row, col } = posList[i];
          const cell = cellMatrix[row]?.[col];
          if (!cell) continue;
          const val = cell.value.toUpperCase();
          if (val === answer[i]) {
            cell.classList.add('correct');
          } else {
            cell.classList.add('incorrect', 'shake');
            allCorrect = false;
          }
        }
      }

      if(allCorrect) {
        resultMsg.textContent = "🎉 ¡Felicidades! Completaste el crucigrama correctamente.";
        resultMsg.classList.add('success');
      } else {
        resultMsg.textContent = "❌ Hay respuestas incorrectas. Intenta de nuevo.";
        resultMsg.classList.remove('success');
      }
    }

    function resetGrid() {
      const gridEl = crucigramaContainer.querySelector('.crucigrama-grid');
      const inputs = gridEl.querySelectorAll('.cell:not(.empty)');
      inputs.forEach(input => {
        input.value = "";
        input.classList.remove('correct', 'incorrect', 'shake');
      });
      resultMsg.textContent = "";
      resultMsg.classList.remove('success');
    }

    function nextCrucigrama() {
      current = (current + 1) % crucigramas.length;
      renderCurrent();
    }

    checkBtn.addEventListener('click', checkAnswers);
    resetBtn.addEventListener('click', resetGrid);
    nextBtn.addEventListener('click', nextCrucigrama);

    // Primer render
    renderCurrent();

  </script>

</body>
</html>
