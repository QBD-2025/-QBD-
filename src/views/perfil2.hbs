<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>QueBuenDato.com</title>
  <link rel="stylesheet" href="/css/perfil.css" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
</head>
<body>

  <!-- Texto de bienvenida -->
  <div class="bienvenida-texto">¡Bienvenido!</div>

  <!-- Contenedor de frases -->
  <div class="perfil-container">
    <div class="perfil-frase frase1">
      <i class="fas fa-running icon" style="color: var(--color-primary);"></i>
      <span class="amarillo">
        <i class="fas fa-book icon"></i>¿Examen pronto? No te preocupes, repasalo con nosotros 💪
      </span>
    </div>

    <div class="perfil-frase frase2">
      <i class="fas fa-gamepad icon" style="color: var(--color-secondary);"></i>
      <span class="azulito">¿Aburrido? Juega un juego rápido y aprende algo nuevo 😎</span>
    </div>

    <div class="perfil-frase frase3">
      <i class="fas fa-search icon" style="color: #00D1A0;"></i>
      An
    </div>

    <div class="perfil-frase frase4">
      <i class="fas fa-trophy icon" style="color: var(--color-accent);"></i>
      <span class="azulito">Nadie puede ser mejor que yo. Compite con tus amigos y sé el mejor siempre 🔥</span>
    </div>

    <div class="perfil-frase frase5">
      <i class="fas fa-brain icon" style="color: #00C9FF;"></i>
      <span class="verdeagua">¿Te sientes olvidadizo?<br>¡Repasemos! 💯</span>
    </div>

    <div class="perfil-frase frase6">
      <i class="fas fa-book-reader icon" style="color: #A569BD;"></i>
      <br />
      <img src="/images/.png" alt="S" style="max-width: 100%; border-radius: 12px;" />
    </div>
  </div>

  <!-- Música oculta -->
  <button id="playMusic" style="display: none;">Reproducir Música</button>
  <audio id="musica" loop>
    <source src="/Audio/bby_no.mp3" type="audio/mpeg" />
  </audio>

  <!-- Script principal -->
  <script src="/js/main.js"></script>

  <!-- Animación explosiva GSAP -->
  <script>
    window.addEventListener('load', () => {
      // Animación del texto de bienvenida tipo estallido suave
      gsap.from(".bienvenida-texto", {
        scale: 0,
        opacity: 0,
        duration: 0.8,
        ease: "back.out(2)"
      });

      // Explosión visual desde el centro de todos los cuadros
      gsap.from(".perfil-frase", {
        scale: 0,
        opacity: 0,
        rotation: 90,
        duration: 1,
        ease: "elastic.out(1, 0.4)",
        stagger: {
          each: 0.2,
          grid: "auto",
          from: "center"
        }
      });
    });
  </script>
</body>
</html>
