<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Perfil</title>
<link rel="stylesheet" href="/css/perfil.css">
{{!-- 
  VISTA DE PERFIL / DASHBOARD
  Esta es la primera página que ve un usuario al iniciar sesión.
--}}

<div class="perfil-wrapper">

  {{!-- Encabezado de bienvenida personalizado --}}
  <header class="perfil-header">
    {{!-- Usamos la variable 'user' que hicimos disponible en todas las vistas --}}
    <h1>¡Bienvenido de nuevo, <span class="highlight-yellow">{{user.username}}</span>!</h1>
    <p>¿Qué te gustaría hacer hoy?</p>
  </header>

  {{!-- Grid con las opciones principales de la aplicación --}}
  <main class="dashboard-grid">


    {{!-- Tarjeta para el Dato del Día --}}
    <div class="dashboard-card card-fact">
      <div class="card-icon">
        <img src="/media/images/icon-idea.png" alt="Dato del día">
      </div>
      <h3>Dato del Día</h3>
      <p>"Los pulpos tienen tres corazones. Dos bombean sangre a las branquias y uno al resto del cuerpo."</p>
    </div>
    
    {{!-- Tarjeta para la configuración de la cuenta --}}
    <a href="/usuario" class="dashboard-card card-settings">
      <div class="card-icon">
          <img src="/media/images/icon-settings.png" alt="Configuración">
      </div>
      <h3>Mi Cuenta</h3>
      <p>Administra tu información personal, contraseña y preferencias.</p>
    </a>

  </main>

</div>