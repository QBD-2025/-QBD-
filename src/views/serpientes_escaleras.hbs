<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Serpientes y Escaleras</title>
    <link rel="stylesheet" href="/css/serpientes-escaleras.css">
</head>
<body>
    <div class="page">
        <div class="header">
            <div class="title">🐍 Serpientes y Escaleras</div>
            <div class="pill">
                Jugador: <strong>{{#if user}}{{user.username}}{{else}}Invitado{{/if}}</strong>
            </div>
            <button onclick="location.href='/minijuegos'">← Regresar</button>
        </div>

        <div class="game-container">
            <section class="game card">
                {{!-- El tablero se generará aquí con JavaScript --}}
                <div id="tablero"></div>
                
                <div class="controles-juego">
                    <div id="info-turno">Esperando jugadores...</div>
                    <div id="dado-container">
                        <div id="dado" class="dado-animado">
                            <div class="cara cara-1">1</div>
                            <div class="cara cara-2">2</div>
                            <div class="cara cara-3">3</div>
                            <div class="cara cara-4">4</div>
                            <div class="cara cara-5">5</div>
                            <div class="cara cara-6">6</div>
                        </div>
                        <button id="lanzar-dado-btn" disabled>Lanzar Dado 🎲</button>
                    </div>
                </div>
            </section>

            <aside class="side">
                <div class="panel card" id="jugadores-panel">
                    <h3>🟢 Jugadores en la sala</h3>
                    <ul id="lista-jugadores-sala"></ul>
                </div>
                <div class="panel card" id="log-panel">
                    <h3>📜 Historial de la Partida</h3>
                    <div id="logBox"></div>
                </div>
            </aside>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', () => {
        // ================== 1. INICIALIZACIÓN Y VARIABLES ==================
        const socket = io();
        const salaId = "{{salaId}}";
        const usuario = {{{json user}}};

        // --- Elementos del DOM ---
        const tableroDiv = document.getElementById('tablero');
        const lanzarDadoBtn = document.getElementById('lanzar-dado-btn');
        const dadoDiv = document.getElementById('dado');
        const infoTurnoDiv = document.getElementById('info-turno');
        const listaJugadoresSalaEl = document.getElementById('lista-jugadores-sala');
        const logBox = document.getElementById('logBox');
        
        // --- Estado del cliente ---
        const fichasJugadores = {}; // Guarda los elementos DIV de las fichas
        const colores = ['#E74C3C', '#3498DB', '#2ECC71', '#F1C40F', '#9B59B6']; // Colores para fichas

        // ================== 2. FUNCIONES DE RENDERIZADO (UI) ==================

        /**
         * Genera el tablero de 10x10. Se ejecuta una sola vez.
         */
        function crearTablero() {
            tableroDiv.innerHTML = '';
            for (let i = 1; i <= 100; i++) {
                const casilla = document.createElement('div');
                casilla.classList.add('casilla');
                casilla.id = `casilla-${i}`;
                
                const numeroCasilla = document.createElement('span');
                numeroCasilla.textContent = i;
                casilla.appendChild(numeroCasilla);

                tableroDiv.appendChild(casilla);
            }
        }
        
        /**
         * Actualiza el tablero completo, moviendo fichas y actualizando la lista de jugadores.
         */
        function actualizarTableroUI(jugadores) {
            // Limpiar todas las fichas existentes para redibujar
            Object.values(fichasJugadores).forEach(ficha => ficha.remove());

            listaJugadoresSalaEl.innerHTML = '';
            
            jugadores.forEach((jugador, index) => {
                // Crear ficha si no existe
                if (!fichasJugadores[jugador.id]) {
                    const ficha = document.createElement('div');
                    ficha.classList.add('ficha');
                    ficha.textContent = jugador.username.charAt(0).toUpperCase();
                    ficha.style.backgroundColor = colores[index % colores.length];
                    fichasJugadores[jugador.id] = ficha;
                }
                
                // Mover la ficha a su nueva casilla
                const fichaEl = fichasJugadores[jugador.id];
                const casillaDestino = document.getElementById(`casilla-${jugador.posicion}`);
                if (casillaDestino) {
                    casillaDestino.appendChild(fichaEl);
                }

                // Actualizar lista lateral
                const li = document.createElement('li');
                li.innerHTML = `<span class="ficha-indicador" style="background-color: ${colores[index % colores.length]}"></span> ${jugador.username} (Casilla: ${jugador.posicion})`;
                listaJugadoresSalaEl.appendChild(li);
            });
        }

        /**
         * Muestra los mensajes del log del juego en el panel lateral.
         */
        function actualizarLog(log = []) {
            logBox.innerHTML = '';
            log.forEach(mensaje => {
                const p = document.createElement('p');
                p.textContent = `> ${mensaje}`;
                logBox.appendChild(p);
            });
            logBox.scrollTop = logBox.scrollHeight; // Auto-scroll hacia abajo
        }

        /**
         * Anima el dado y muestra el resultado final.
         */
        function animarDado(resultadoFinal) {
            dadoDiv.classList.add('girando'); // Inicia animación CSS
            setTimeout(() => {
                dadoDiv.classList.remove('girando'); // Detiene animación
                // Muestra la cara correcta del dado
                dadoDiv.style.transform = `rotateX(0deg) rotateY(0deg)`; // Resetea
                switch (resultadoFinal) {
                    case 1: dadoDiv.style.transform = 'rotateY(0deg)'; break;
                    case 2: dadoDiv.style.transform = 'rotateX(-90deg)'; break;
                    case 3: dadoDiv.style.transform = 'rotateY(90deg)'; break;
                    case 4: dadoDiv.style.transform = 'rotateY(-90deg)'; break;
                    case 5: dadoDiv.style.transform = 'rotateX(90deg)'; break;
                    case 6: dadoDiv.style.transform = 'rotateY(180deg)'; break;
                }
            }, 1000); // Duración de la animación
        }


        // ================== 3. LÓGICA DEL JUEGO Y SOCKETS ==================

        // Unirse a la sala al cargar la página
        socket.emit('serpientes:unirse', { salaId, usuario });

        // Listener principal para el estado del juego
        socket.on('serpientes:estado', (sala) => {
            console.log("Estado actualizado:", sala); // Para depurar

            actualizarTableroUI(sala.jugadores);
            actualizarLog(sala.log);

            // Animar el dado si hubo un lanzamiento
            if (sala.dado > 0) {
                animarDado(sala.dado);
            }

            // Actualizar información del turno y estado del juego
            if (sala.ganador) {
                infoTurnoDiv.innerHTML = `🏆 <strong>¡Juego Terminado!</strong> 🏆<br/>Ganador: ${sala.ganador.username}`;
                lanzarDadoBtn.disabled = true;
                lanzarDadoBtn.textContent = "Partida Finalizada";
            } else if (sala.jugadores.length > 0) {
                const jugadorDeTurno = sala.jugadores[sala.turnoActualIndex];
                infoTurnoDiv.innerHTML = `Turno de: <strong>${jugadorDeTurno.username}</strong>`;
                
                // Habilitar el botón solo si es mi turno
                lanzarDadoBtn.disabled = (jugadorDeTurno.id !== usuario.id_usuario);
            } else {
                infoTurnoDiv.textContent = 'Esperando más jugadores...';
            }
        });

        // Listener para errores (ej. sala llena)
        socket.on('serpientes:error', (error) => {
            alert(error.mensaje);
            window.location.href = '/minijuegos'; // Redirigir si hay un error
        });

        // Evento para lanzar el dado al hacer click
        lanzarDadoBtn.addEventListener('click', () => {
            lanzarDadoBtn.disabled = true; // Prevenir doble click
            socket.emit('serpientes:lanzarDado', { salaId, userId: usuario.id_usuario });
        });
        

        // ================== 4. EJECUCIÓN INICIAL ==================
        crearTablero();
    });
    </script>
</body>
</html>