<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dato Curioso</title>
  <link rel="stylesheet" href="/css/dato_aleatorio.css" />
</head>
<body>

<svg viewBox="0 0 100 100" class="fondo">
  <!-- Decoraciones en las esquinas -->
  
  <div class="decoracion esquina-derecha-superior"></div>
  <div class="decoracion esquina-izquierda-inferior"></div>


  <div class="contenedor-dato">
    
    <!-- Recuadro amarillo (imagen o ilustración) -->
    <div class="recuadro-imagen">
      <!-- Puedes usar imagen real o solo fondo amarillo -->
      <!-- <img src="/ruta/imagen.jpg" alt="Ilustración del dato" /> 
    </div>

    <!-- Texto del dato curioso -->
    <div class="contenido-dato">
      <h1>{{materia}}</h1>
      <p>{{dato}}</p>
    </div>

  </div>
</body>
</html>
