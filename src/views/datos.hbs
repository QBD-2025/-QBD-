<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dato Curioso</title>
  <link rel="stylesheet" href="/css/dato_aleatorio.css" />
</head>
<body>

  
  <div class="contenedor-dato">
    
    <!-- Recuadro amarillo (imagen o ilustración) -->
    <div class="recuadro-imagen">
      <!-- Puedes usar imagen real o solo fondo amarillo -->
      <!-- <img src="/ruta/imagen.jpg" alt="Ilustración del dato" /> -->
    </div>

    <!-- Texto del dato curioso -->
    <div class="contenido-dato">
      <h1>{{materia}}</h1>
      <p>{{dato}}</p> <!-- Este es el texto que viene desde la base de datos -->
    </div>

  </div>
</body>
</html>
